3) DB Schema (Locked DDL)

-- Payment providers config (metadata, NOT secrets)
CREATE TABLE payment_providers (
  id UUID PRIMARY KEY,
  tenant_id UUID NOT NULL REFERENCES tenants(id) ON DELETE CASCADE,
  provider_key TEXT NOT NULL, -- e.g., 'WOMPI'
  enabled BOOL NOT NULL DEFAULT FALSE,
  config JSONB NULL, -- non-secret config/flags
  created_at TIMESTAMPTZ DEFAULT now()
);
CREATE UNIQUE INDEX ux_payment_providers_tenant_provider ON payment_providers(tenant_id, provider_key);

-- Payment attempts
CREATE TABLE payment_attempts (
  id UUID PRIMARY KEY,
  tenant_id UUID NOT NULL REFERENCES tenants(id) ON DELETE CASCADE,
  order_id UUID NOT NULL REFERENCES orders(id) ON DELETE CASCADE,
  provider TEXT NULL,
  provider_attempt_id TEXT NULL,
  method TEXT NOT NULL,
  amount_cents BIGINT NOT NULL CHECK (amount_cents >= 0),
  currency CHAR(3) NOT NULL DEFAULT 'COP',
  status TEXT NOT NULL, -- enum like PENDING,PENDING_PROVIDER,PAID,FAILED,REFUNDED,CANCELLED
  metadata JSONB NULL,
  idempotency_key TEXT NULL,
  created_at TIMESTAMPTZ DEFAULT now(),
  updated_at TIMESTAMPTZ DEFAULT now()
);
CREATE INDEX idx_payment_attempts_order ON payment_attempts(order_id);
CREATE INDEX idx_payment_attempts_tenant ON payment_attempts(tenant_id);
CREATE UNIQUE INDEX ux_payment_attempts_idempo_tenant_order ON payment_attempts(tenant_id, idempotency_key, order_id) WHERE idempotency_key IS NOT NULL;

-- Refunds (MVP full refunds only)
CREATE TABLE refunds (
  id UUID PRIMARY KEY,
  tenant_id UUID NOT NULL REFERENCES tenants(id) ON DELETE CASCADE,
  order_id UUID NOT NULL REFERENCES orders(id) ON DELETE CASCADE,
  payment_attempt_id UUID NULL REFERENCES payment_attempts(id),
  amount_cents BIGINT NOT NULL,
  method TEXT NOT NULL, -- OFFLINE or PROVIDER
  provider_ref TEXT NULL,
  status TEXT NOT NULL DEFAULT 'COMPLETED',
  created_at TIMESTAMPTZ DEFAULT now()
);

Note: enforce tenant scoping at service layer; consider triggers later for DB-level tenant safety.

